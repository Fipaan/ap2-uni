      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('idem_key')) {",
                  "  pm.collectionVariables.set('idem_key', `idem-${Date.now()}-${Math.random().toString(16).slice(2)}`);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200 or 201', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('response is JSON', function () {",
                  "  pm.response.to.be.json;",
                  "});",
                  "",
                  "pm.test('order has expected structure', function () {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j).to.have.property('ID');",
                  "  pm.expect(j).to.have.property('CustomerID', 'cust-123');",
                  "  pm.expect(j).to.have.property('ItemName', 'Keyboard');",
                  "  pm.expect(j).to.have.property('Amount', 4999);",
                  "  pm.expect(j).to.have.property('Status', 'Authorized');",
                  "  pm.expect(j).to.have.property('CreatedAt');",
                  "  pm.expect(j).to.have.property('IdempotencyKey', pm.collectionVariables.get('idem_key'));",
                  "});",
                  "",
                  "pm.test('order id is saved for later tests', function () {",
                  "  const j = pm.response.json();",
                  "  pm.collectionVariables.set('order_id', j.ID);",
                  "  pm.collectionVariables.set('payment_order_id', j.ID);",
                  "  pm.collectionVariables.set('timed_order_id', j.ID);",
                  "  pm.expect(pm.collectionVariables.get('order_id')).to.eql(j.ID);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{idem_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"cust-123\",\n  \"item_name\": \"Keyboard\",\n  \"amount\": 4999\n}"
            },
            "url": {
              "raw": "{{order_base_url}}/orders",
              "host": ["{{order_base_url}}"],
              "path": ["orders"]
            }
          }
