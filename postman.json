    {
      "name": "Notifications (EDA Flow)",
      "description": "Tests the event-driven flow: Order -> Payment -> RabbitMQ -> Notification Service. Uses RabbitMQ Management API (http://localhost:15672) to verify queue state.",
      "item": [
        {
          "name": "Create Order (triggers notification)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('notification_idem_key', `notify-${Date.now()}-${Math.random().toString(16).slice(2)}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('order created successfully', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('order is authorized - event will be published', function () {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j).to.have.property('Status', 'Authorized');",
                  "  pm.collectionVariables.set('notification_order_id', j.ID);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{notification_idem_key}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"cust-notify\",\n  \"customer_email\": \"notify@example.com\",\n  \"item_name\": \"Headphones\",\n  \"amount\": 7999\n}"
            },
            "url": {
              "raw": "{{order_base_url}}/orders",
              "host": ["{{order_base_url}}"],
              "path": ["orders"]
            }
          }
        },
        {
          "name": "Verify payment.completed.q is active (RabbitMQ)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200 - queue exists', function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "});",
                  "",
                  "pm.test('queue is durable', function () {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j).to.have.property('durable', true);",
                  "});",
                  "",
                  "pm.test('queue has expected name', function () {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j).to.have.property('name', 'payment.completed.q');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
