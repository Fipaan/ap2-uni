            }
          }
        },
        {
          "name": "Get Timed Order After 6 Seconds",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const start = Date.now();",
                  "while (Date.now() - start < 6100) {}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "});",
                  "",
                  "pm.test('timed order is no longer pending after 5 seconds', function () {",
                  "  const j = pm.response.json();",
                  "  pm.expect(j).to.have.property('ID', pm.collectionVariables.get('timed_order_id'));",
                  "  pm.expect(j.Status).to.not.eql('Pending');",
                  "  pm.expect(j.Status).to.be.oneOf(['Authorized', 'Paid', 'Failed', 'Cancelled']);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{order_base_url}}/orders/{{timed_order_id}}",
              "host": ["{{order_base_url}}"],
              "path": ["orders", "{{timed_order_id}}"]
            }
          }
        },
